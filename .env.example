# Unkey (API key auth + rate limiting)
UNKEY_ROOT_KEY=
UNKEY_API_ID=
UNKEY_RATELIMIT_NAMESPACE=galaxy-api
UNKEY_RATELIMIT_NAME=requests
UNKEY_RATELIMIT_LIMIT=100
UNKEY_RATELIMIT_DURATION=60s
UNKEY_RATELIMIT_DURATION_MS=60000

# Local development API key (used when Unkey is not configured)
DEV_API_KEY=gal_dev_test_key_12345
DEV_RATELIMIT_LIMIT=100
DEV_RATELIMIT_WINDOW_MS=60000

# Database (required)
DATABASE_URL=postgresql://galaxy:galaxy@localhost:5432/galaxy

# Clerk (required for UI auth; API keys work without Clerk when using gal_ tokens)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
FRONTEND_URL=http://localhost:3000

# Dev auth bypass (local only — never in production)
# AUTH_DISABLED=true
# MOCK_OWNER_USER_ID=user_dev_local

# Transloadit (file storage — upload bytes, get public HTTPS URLs)
# Secrets stay on the backend; the browser only calls /api/v1/uploads.
# Auth key + secret alone enable uploads (trial default — may return temporary scratch URLs).
TRANSLOADIT_AUTH_KEY=
TRANSLOADIT_AUTH_SECRET=
# Optional — durable export for production (credentials live in Transloadit dashboard, not here):
TRANSLOADIT_TEMPLATE_ID=
# Optional — inline durable export without a dashboard template (credential name from Transloadit):
TRANSLOADIT_STORE_CREDENTIALS=
# Export robot when using store credentials (default /cloudflare/store; use /s3/store for S3)
# TRANSLOADIT_STORE_ROBOT=/cloudflare/store
# Optional — reject scratch URLs and require template or store creds (default: accept scratch URLs)
# TRANSLOADIT_REQUIRE_DURABLE_URLS=true

# Trigger.dev (required — all workflow execution runs via Trigger tasks)
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=
# Set to 1 to run live Trigger.dev integration tests (requires `pnpm trigger:dev` + DATABASE_URL)
TRIGGER_INTEGRATION=

# OpenRouter (LLM node — free tier)
OPENROUTER_API_KEY=
# Optional OpenRouter attribution headers
# OPENROUTER_HTTP_REFERER=https://galaxy.ai
# OPENROUTER_APP_TITLE=Galaxy Workflow Builder

